{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": [
      "vite/client",
      "jest",
      "@testing-library/jest-dom"
    ],
    "outDir": "./dist/ts",
    "tsBuildInfoFile": "dist/ts/.tsbuildinfo"
  },
  "include": [
    "src/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "src/**/*.cy.ts",
    "src/**/*.cy.tsx"
  ],
  "references": [
    {
      "path": "../common"
    },
  ]
}