{
  "name": "@notion-site/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./env.js": {
      "types": "./dist/ts/src/env.d.ts",
      "default": "./dist/server/env.js"
    },
    "./server.js": {
      "types": "./dist/ts/src/server.d.ts",
      "default": "./dist/server/server.js"
    },
    "./rss.js": {
      "types": "./dist/ts/src/rss.d.ts",
      "default": "./dist/server/rss.js"
    }
  },
  "scripts": {
    "dev": "dotenvx run -f ../.env -- vite",
    "clean": "tsc -b --clean && rm -rf dist",
    "build": "npm run build:ts && npm run build:client && npm run build:server",
    "build:ts": "tsc -b",
    "build:client": "dotenvx run -f ../.env -- vite build",
    "build:server": "dotenvx run -f ../.env -- vite build --ssr",
    "preview": "dotenvx run -f ../.env -- vite preview"
  },
  "dependencies": {
    "@notion-site/common": "*",
    "@orpc/client": "^1.13.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-router": "^7.13.0",
    "suspend-react": "^0.1.3",
    "typescript-event-target": "^1.1.2",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "jest-environment-jsdom": "^30.2.0",
    "prism-themes": "^1.9.0",
    "sass": "^1.97.3",
    "vite": "^7.3.1",
    "web-streams-polyfill": "^4.2.0"
  }
}
