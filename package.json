{
  "name": "@gabiseabra/notion-site",
  "private": true,
  "version": "0.1.0",
  "description": "Notion‑backed blog with API contracts, api server and web application.",
  "workspaces": [
    "api",
    "web",
    "common"
  ],
  "scripts": {
    "build": "npm run build -w common && npm run build -w api && npm run build -w web",
    "clean": "npm run clean -w common && npm run clean -w api && npm run clean -w web",
    "start": "npm run start -w api",
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "lint": "eslint \"{api,web,common}/src/**/*.{ts,tsx}\"",
    "tsc": "tsc -b",
    "cy:open": "cypress open --component --browser electron",
    "test": "NODE_OPTIONS=--experimental-vm-modules node --loader ts-node/esm ./node_modules/jest/bin/jest.js -c jest.config.ts --",
    "test:common": "NODE_OPTIONS=--experimental-vm-modules node --loader ts-node/esm ./node_modules/jest/bin/jest.js -c jest.config.ts --selectProjects common --",
    "test:api": "NODE_OPTIONS=--experimental-vm-modules node --loader ts-node/esm ./node_modules/jest/bin/jest.js -c jest.config.ts --selectProjects api --",
    "test:web": "NODE_OPTIONS=--experimental-vm-modules node --loader ts-node/esm ./node_modules/jest/bin/jest.js -c jest.config.ts --selectProjects web --",
    "test:cy": "cypress run --component"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "concurrently": "^9.2.1",
    "cypress": "^15.10.0",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "ts-functional-pipe": "^3.1.2",
    "ts-pattern": "^5.9.0",
    "uuid": "^13.0.0"
  }
}
